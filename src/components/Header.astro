---
import DesktopMenu from "./desktop-menu.astro"
import MobileMenu from './mobile-menu.astro';
---

<nav class="w-full border-b border-gray-200 relative">
    <div class="max-w-6xl mx-auto flex items-center justify-between px-6 py-4">
        <!-- Логотип -->
        <div class="flex items-center">
            <a href="/solar-series/">
                <img src="/solar-series/img/rahim_portrait2_black.png" class="w-6">
            </a>
        </div>

        <DesktopMenu />

        <!-- Переключатель темы и Кнопка Войти (ПК)-->
        <div class="flex align-center gap-2">
            <a href="https://course.marlindev.ru" class="hidden md:inline font-medium text-sm hover:text-gray-600 transition">
            Войти
            </a>
            <button id="theme-toggle" class="ml-4  focus:outline-none cursor-pointer">
                <svg id="icon-sun" class="w-5 h-5 hidden dark:text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                    d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
                </svg>
                <svg id="icon-moon" class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                    d="M21 12.79A9 9 0 1111.21 3a7 7 0 009.79 9.79z" />
                </svg>
            </button>
            <!-- Бургер (мобильный) -->
            <button id="menu-toggle" class="md:hidden text-gray-800 dark:text-gray-300 focus:outline-none">
                <svg id="menu-open-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none"
                    viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16" />
                </svg>
                <svg id="menu-close-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" fill="none"
                    viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
    </div>

    <MobileMenu />
</nav>

